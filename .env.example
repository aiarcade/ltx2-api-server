# Required: Get a free key from https://console.ltx.video
LTX_API_KEY=your_key_here

# Optional: Override model weights location (default: ./models/ltx-2.3)
# LTX_MODEL_DIR=./models/ltx-2.3

# Optional: Override output directory (default: ./outputs)
# LTX_OUTPUT_DIR=./outputs

# Optional: Override API base URL used for text encoding
# LTX_API_BASE=https://api.ltx.video

# Optional: Maximum number of jobs to keep in history (default: 100)
# LTX_MAX_JOBS=100

# Optional: Path to local Gemma model (fallback if API key not set, needs ≥48GB VRAM)
# GEMMA_ROOT=/path/to/gemma-3-12b-it

# ── LTX-Desktop compatibility (LTX Console API drop-in) ──────────────────
# Bearer token clients must send to /v1/* endpoints.
# Set this to the same value you enter as the "API Key" in LTX-Desktop
# settings so that the Desktop's Bearer header is accepted by this server.
# Leave empty to skip auth (safe for private LANs).
# LTX_CONSOLE_API_KEY=your_secret_token_here
